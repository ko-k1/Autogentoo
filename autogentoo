    esp_uuid=$(blkid -s UUID -o value "$ESP_PART")
    [[ -n $root_uuid && -n $esp_uuid ]] || die "Filesystem UUID discovery failed."
    cat >"$TARGET/etc/fstab" <<EOF
UUID=$root_uuid / btrfs noatime,compress=zstd:1,subvol=@ 0 0
UUID=$root_uuid /home btrfs noatime,compress=zstd:1,subvol=@home 0 0
UUID=$esp_uuid /efi vfat umask=0077,nodev,nosuid,noexec 0 2
EOF
    if (( SWAP_MIB )); then
        cat >>"$TARGET/etc/fstab" <<EOF
UUID=$root_uuid /.swap btrfs noatime,compress=zstd:1,subvol=@swap 0 0
/.swap/swapfile none swap defaults 0 0
EOF
