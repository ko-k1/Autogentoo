    [[ $ARCH == amd64 ]] && grub_target=x86_64-efi || grub_target=arm64-efi
    root_uuid=$(blkid -s UUID -o value "$ROOT_PART")
    [[ -n $root_uuid ]] || die "The bootloader root UUID could not be read."
    [[ $MODE == whole ]] && bootloader_id=Gentoo || bootloader_id="Gentoo-$root_uuid"
    if [[ $MODE == whole ]]; then
        chroot_run /usr/sbin/grub-install --target="$grub_target" --efi-directory=/efi \
            --bootloader-id="$bootloader_id" --removable
        if ! chroot_run /usr/sbin/grub-install --target="$grub_target" --efi-directory=/efi \
            --bootloader-id="$bootloader_id"; then
            log "WARNING: NVRAM boot entry creation failed; the removable fallback remains installed"
        fi
    else
        chroot_run /usr/sbin/grub-install --target="$grub_target" --efi-directory=/efi \
            --bootloader-id="$bootloader_id"
    fi
    chroot_run /usr/sbin/grub-mkconfig -o /boot/grub/grub.cfg
}

perform_install() {
    storage_plan_still_valid || die "Storage changed before installation; no target disk write was made."
    prepare_stage_metadata
    run mkdir -p "$TARGET"
    storage_plan_still_valid || die "Storage changed while release metadata was verified; no target disk write was made."
    setup_storage
    mount_layout
    download_and_extract_stage
    bind_chroot_filesystems
    write_system_configuration
    install_base
    if [[ $PROFILE == desktop ]]; then
        install_desktop
    fi
    create_user
    if [[ $PROFILE == desktop ]]; then
        write_hyprland_config
    fi
    write_fstab
    install_bootloader
    run mkdir -p "$TARGET/var/log"
    run install -m 600 "$LOG" "$TARGET/var/log/autogentoo.log"
    log "Installation completed successfully"
}

main() {
    local arg
    for arg in "$@"; do
        case $arg in
            --dry-run) DRY_RUN=1 ;;
            --help|-h) usage; return 0 ;;
            --version) printf 'Autogentoo %s\n' "$VERSION"; return 0 ;;
            *) usage >&2; return 2 ;;
        esac
    done
    LOG=$(mktemp /tmp/autogentoo.XXXXXX.log)
    preflight
    collect_profile
    collect_storage
    collect_swap
    collect_identity
    review_and_confirm
    if (( DRY_RUN )); then
        return 0
    fi
    perform_install
    dialog_message "Gentoo is installed. The target will now be unmounted cleanly.\n\nRemove the live media and reboot.\nLog: $LOG"
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    main "$@"
fi
