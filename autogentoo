install_desktop() {
    local packages=(
        '=gui-wm/hyprland-0.55.4-r1'
        gui-apps/waybar gui-apps/fuzzel gui-apps/foot gui-apps/mako
        gui-apps/hyprpaper gui-apps/hyprlock gui-apps/hypridle
        gui-libs/xdg-desktop-portal-hyprland sys-apps/xdg-desktop-portal
        sys-apps/xdg-desktop-portal-gtk media-video/pipewire media-video/wireplumber
        sys-auth/polkit sys-auth/hyprpolkitagent gnome-extra/nm-applet
        gui-apps/wl-clipboard gui-apps/grim gui-apps/slurp
        media-fonts/dejavu media-fonts/noto app-misc/brightnessctl
        media-sound/playerctl www-client/firefox-bin
    )
    chroot_run /usr/bin/emerge --verbose --newuse app-eselect/eselect-repository dev-vcs/git
    pin_repository hyproverlay "$HYPROVERLAY_COMMIT"
    printf '*/*::hyproverlay ~amd64\n' >"$TARGET/etc/portage/package.accept_keywords/hyproverlay"
    cat >"$TARGET/etc/portage/package.use/hyprland" <<'EOF'
gui-wm/hyprland X -systemd -uwsm
media-video/pipewire sound-server
EOF
    if (( NVIDIA )); then
        cat >>"$TARGET/etc/portage/package.use/hyprland" <<'EOF'
x11-drivers/nvidia-drivers kernel-open wayland dist-kernel
EOF
        printf 'options nvidia_drm modeset=1 fbdev=1\n' >"$TARGET/etc/modprobe.d/nvidia.conf"
        packages+=(x11-drivers/nvidia-drivers)
    fi
    if [[ $DISPLAY_MANAGER == sddm ]]; then
        packages+=(x11-misc/sddm gui-libs/display-manager-init)
    else
        pin_repository guru "$GURU_COMMIT"
        printf 'x11-misc/ly::guru ~amd64\n' >"$TARGET/etc/portage/package.accept_keywords/ly"
        packages+=(x11-misc/ly)
    fi
    chroot_run /usr/bin/emerge --verbose --newuse "${packages[@]}"
    reattach_repository hyproverlay
    if [[ $DISPLAY_MANAGER == ly ]]; then
        reattach_repository guru
        chroot_run /sbin/rc-update del agetty.tty2 default || true
        chroot_run /sbin/rc-update add ly default
        [[ ! -f $TARGET/etc/ly/config.ini ]] || sed -i -E 's/^[# ]*tty[ ]*=.*/tty = 2/' "$TARGET/etc/ly/config.ini"
    else
        printf 'CHECKVT=7\nDISPLAYMANAGER="sddm"\n' >"$TARGET/etc/conf.d/display-manager"
        run mkdir -p "$TARGET/etc/sddm.conf.d"
        printf '[General]\nDisplayServer=x11\n' >"$TARGET/etc/sddm.conf.d/autogentoo.conf"
        chroot_run /sbin/rc-update add display-manager default
    fi
    chroot_run /sbin/rc-update add elogind boot
    write_hyprland_config
}

create_user() {
    local groups=wheel,video
    [[ $PROFILE == desktop ]] && groups+=,audio,input
    chroot_run /usr/sbin/useradd -m -G "$groups" -s /bin/bash "$USERNAME"
    printf '%s:%s\n' "$USERNAME" "$USER_PASSWORD" | chroot "$TARGET" /usr/sbin/chpasswd
    if (( ROOT_SAME_PASSWORD )); then
        printf 'root:%s\n' "$USER_PASSWORD" | chroot "$TARGET" /usr/sbin/chpasswd
    else
        chroot_run /usr/bin/passwd -l root
    fi
    unset USER_PASSWORD
    run mkdir -p "$TARGET/etc/sudoers.d"
    cat >"$TARGET/etc/sudoers.d/wheel" <<'EOF'
%wheel ALL=(ALL:ALL) ALL
EOF
    chmod 0440 "$TARGET/etc/sudoers.d/wheel"
    chroot_run /usr/sbin/visudo -cf /etc/sudoers
}

write_fstab() {
    local root_uuid esp_uuid
    root_uuid=$(blkid -s UUID -o value "$ROOT_PART")
    esp_uuid=$(blkid -s UUID -o value "$ESP_PART")
    [[ -n $root_uuid && -n $esp_uuid ]] || die "Filesystem UUID discovery failed."
    cat >"$TARGET/etc/fstab" <<EOF
UUID=$root_uuid / btrfs noatime,compress=zstd:1,subvol=@ 0 0
UUID=$root_uuid /home btrfs noatime,compress=zstd:1,subvol=@home 0 0
UUID=$esp_uuid /efi vfat umask=0077 0 2
EOF
    if (( SWAP_MIB )); then
        cat >>"$TARGET/etc/fstab" <<EOF
UUID=$root_uuid /.swap btrfs noatime,compress=zstd:1,subvol=@swap 0 0
/.swap/swapfile none swap defaults 0 0
EOF
    fi
}

install_bootloader() {
    local kernel grub_target
    kernel=$(find "$TARGET/lib/modules" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort -V | tail -n1)
    [[ -n $kernel ]] || die "No installed kernel was found."
    chroot_run /usr/bin/dracut --force --kver "$kernel"
    [[ $ARCH == amd64 ]] && grub_target=x86_64-efi || grub_target=arm64-efi
    chroot_run /usr/sbin/grub-install --target="$grub_target" --efi-directory=/efi --bootloader-id=Gentoo
    if [[ $MODE == whole ]]; then
        chroot_run /usr/sbin/grub-install --target="$grub_target" --efi-directory=/efi --removable
    fi
    chroot_run /usr/sbin/grub-mkconfig -o /boot/grub/grub.cfg
}

perform_install() {
    setup_storage
    mount_layout
    download_and_extract_stage
    bind_chroot_filesystems
    write_system_configuration
    install_base
    create_user
    [[ $PROFILE == desktop ]] && install_desktop
    write_fstab
    install_bootloader
    run mkdir -p "$TARGET/var/log"
    run install -m 600 "$LOG" "$TARGET/var/log/autogentoo.log"
    log "Installation completed successfully"
}

main() {
    local arg
    for arg in "$@"; do
        case $arg in
            --dry-run) DRY_RUN=1 ;;
            --help|-h) usage; return 0 ;;
            --version) printf 'Autogentoo %s\n' "$VERSION"; return 0 ;;
            *) usage >&2; return 2 ;;
        esac
    done
    LOG=$(mktemp /tmp/autogentoo.XXXXXX.log)
    preflight
    collect_profile
    collect_storage
    collect_swap
    collect_identity
    review_and_confirm || return 0
    perform_install
    dialog_message "Gentoo is installed. The target will now be unmounted cleanly.\n\nRemove the live media and reboot.\nLog: $LOG"
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
    main "$@"
fi
