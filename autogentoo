pin_repository() {
    local name=$1 commit=$2 repo=/var/db/repos/$1 actual
    chroot_run /usr/bin/eselect repository enable "$name"
    chroot_run /usr/sbin/emaint sync -r "$name"
    chroot_run /usr/bin/git -C "$repo" fetch origin "$commit"
    chroot_run /usr/bin/git -C "$repo" checkout --detach "$commit"
    actual=$(chroot "$TARGET" /usr/bin/env -i HOME=/root \
        PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
        /usr/bin/git -C "$repo" rev-parse HEAD) || die "Failed to verify the pinned $name commit."
    [[ $actual == "$commit" ]] ||
        die "Failed to pin $name to its v1 commit."
}

reattach_repository() {
    local name=$1 repo=/var/db/repos/$1 branch
    branch=$(chroot "$TARGET" /usr/bin/env -i HOME=/root \
        PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
        /usr/bin/git -C "$repo" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null || true)
    branch=${branch#origin/}
    [[ -n $branch ]] || branch=master
    chroot_run /usr/bin/git -C "$repo" checkout "$branch"
}

