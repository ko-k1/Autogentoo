#!/bin/bash -p
# Autogentoo v1 - interactive Gentoo OpenRC installer
# SPDX-License-Identifier: GPL-2.0-or-later

set +x
set -Eeuo pipefail
shopt -s extglob nullglob
umask 077
ulimit -c 0
export LC_ALL=C
export PATH=/usr/sbin:/usr/bin:/sbin:/bin
export HOME=/root
unset BASH_ENV ENV CDPATH POSIXLY_CORRECT TAR_OPTIONS XZ_OPT XZ_DEFAULTS GZIP BZIP2 \
    GNUPGHOME DIALOGRC XDG_CONFIG_HOME OPENSSL_CONF OPENSSL_CONF_INCLUDE \
    OPENSSL_MODULES OPENSSL_ENGINES

readonly VERSION="1.0.0"
readonly GENTOO_KEY="/usr/share/openpgp-keys/gentoo-release.asc"
readonly HYPROVERLAY_COMMIT="208de784dfeac00d87dfd153f27b3cd866243dff"
readonly GURU_COMMIT="d5bbb6ac453db1d1280eb0e1ab9e9685c6cd102b"
readonly ESP_GUID="c12a7328-f81f-11d2-ba4b-00a0c93ec93b"
readonly LINUX_GUID="0fc63daf-8483-4772-8e79-3d69d8477de4"
readonly MIB=1048576
readonly GIB=1073741824

DRY_RUN=0
DIALOG_READY=0
TARGET=/mnt/gentoo
LOG=""
WORKDIR=""
STAGE_DIR=""
STAGE_PATH=""
STAGE_SIZE=0
STAGE_DIGEST=""
STAGE_BASE=""
OUR_SWAP=""
TARGET_ACTIVE=0

ARCH=""
CPU_THREADS=1
RAM_MIB=0
GPU_INFO=""
CPU_VENDOR=""
PROFILE="base"
DISPLAY_MANAGER="sddm"
NVIDIA=0
NVIDIA_CONFIRMED=0

MODE=""
DISK=""
ROOT_PART=""
ESP_PART=""
ESP_ACTION="reuse"
ROOT_BYTES=0
ORIGINAL_ROOT_BYTES=0
ORIGINAL_DISK_BYTES=0
ORIGINAL_DISKSEQ=""
ORIGINAL_SECTOR_SIZE=0
ORIGINAL_ROOT_ID=""
ORIGINAL_ESP_ID=""
GAP_START=0
GAP_END=0
ROOT_START=0
ROOT_END=0
SECTOR_SIZE=512
PRESERVED=""
SWAP_MIB=0

LOCALE="en_US.UTF-8"
TIMEZONE="UTC"
KEYMAP="us"
XKB_LAYOUT="us"
HOSTNAME="gentoo"
USERNAME=""
USER_PASSWORD_HASH=""
ROOT_SAME_PASSWORD=0

declare -A PROTECTED_DISKS=()

log() {
    [[ -n $LOG ]] || return 0
    printf '%s %s\n' "$(date -u +%FT%TZ)" "$*" >>"$LOG"
}

quote_command() {
    local arg out=""
    for arg; do
        printf -v arg '%q' "$arg"
        out+="${out:+ }$arg"
    done
    printf '%s' "$out"
}

run() {
    log "+ $(quote_command "$@")"
    "$@" 2>&1 | tee -a "$LOG"
}

chroot_run() {
    log "+ chroot $(quote_command "$@")"
    chroot "$TARGET" /usr/bin/env -i HOME=/root TERM="${TERM:-linux}" \
        PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin "$@" 2>&1 | tee -a "$LOG"
}

dialog_message() {
    if (( DIALOG_READY )); then
        dialog --title "Autogentoo" --msgbox "$1" 10 72 || true
    fi
}

die() {
    log "ERROR: $*"
    dialog_message "$*"
    printf 'autogentoo: %s\n' "$*" >&2
    exit 1
}

on_error() {
    local status=$? line=$1
    (( status == 0 )) && return
    log "ERROR: command failed at line $line (status $status)"
    if (( DIALOG_READY )); then
        dialog --title "Installation failed" --msgbox \
            "A command failed at line $line. The target will be unmounted.\n\nLog: $LOG" 12 72 || true
    fi
    exit "$status"
}

cleanup() {
    local status=$? cleanup_failed=0 mount_status
    trap - ERR EXIT
    set +eu
    unset USER_PASSWORD_HASH
    if [[ -n $OUR_SWAP ]]; then
        swapoff "$OUR_SWAP" >>"$LOG" 2>&1 || cleanup_failed=1
    fi
    if [[ -n $STAGE_DIR && -d $STAGE_DIR ]]; then
        rm -rf -- "$STAGE_DIR" || cleanup_failed=1
    fi
    if (( TARGET_ACTIVE )); then
        if mountpoint -q "$TARGET" 2>/dev/null; then
            if [[ -n $LOG && -d $TARGET/var/log ]]; then
                install -m 600 "$LOG" "$TARGET/var/log/autogentoo.log" 2>/dev/null ||
                    cleanup_failed=1
            fi
            umount -R "$TARGET" >>"$LOG" 2>&1 || cleanup_failed=1
        else
            mount_status=$?
            (( mount_status == 32 )) || cleanup_failed=1
        fi
    fi
    if [[ -n $WORKDIR && -d $WORKDIR ]]; then
        rm -rf -- "$WORKDIR" || cleanup_failed=1
    fi
    if (( cleanup_failed )); then
        printf 'autogentoo: cleanup failed; check swap and mounts before rebooting.\n' >&2
        (( status == 0 )) && status=1
    fi
    exit "$status"
}

trap 'on_error $LINENO' ERR
trap cleanup EXIT

usage() {
    cat <<'EOF'
Usage: sudo ./autogentoo [--dry-run]
       ./autogentoo --help | --version

Interactive Gentoo OpenRC installer for amd64 and arm64 UEFI systems.

  --dry-run  detect hardware and build a TUI plan without target writes,
             downloads, mounts, formatting, partitioning, or chroot
  --help     show this help
  --version  show the version
EOF
}

arch_name() {
    case $1 in
        x86_64) printf 'amd64' ;;
        aarch64) printf 'arm64' ;;
        *) return 1 ;;
    esac
}

valid_hostname() {
    [[ $1 =~ ^[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(\.[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*$ && ${#1} -le 253 ]]
}

valid_username() {
    [[ $1 =~ ^[a-z_][a-z0-9_-]{0,30}$ && $1 != root ]]
}

available_username() {
    valid_username "$1" && [[ $1 != sddm ]] && awk -F: -v name="$1" '
        $1 == name { found=1 }
        END { exit found ? 1 : 0 }
    ' /etc/passwd
}

valid_locale() {
    [[ $1 =~ ^[A-Za-z]{2,3}_[A-Za-z0-9]{2,3}(\.[A-Za-z0-9_-]+)?(@[A-Za-z0-9_-]+)?$ && ${#1} -le 64 ]]
}

supported_locale() {
    valid_locale "$1" && [[ -r /usr/share/i18n/SUPPORTED ]] &&
        grep -Fqx -- "$1 UTF-8" /usr/share/i18n/SUPPORTED
}

valid_layout() {
    [[ $1 =~ ^[A-Za-z0-9_-]{1,32}$ ]]
}

supported_keymap() {
    local keymap=$1 root=${2:-/usr/share/keymaps} match
    valid_layout "$keymap" || return 1
    match=$(find "$root" -type f -name "$keymap.map*" -print -quit 2>/dev/null) ||
        return 1
    [[ -n $match ]]
}

valid_timezone() {
    local timezone=$1 magic
    [[ $timezone != /* && $timezone != *..* && -f /usr/share/zoneinfo/$timezone ]] ||
        return 1
    magic=$(od -An -t x1 -N 4 "/usr/share/zoneinfo/$timezone" 2>/dev/null |
        tr -d '[:space:]') || return 1
    [[ $magic == 545a6966 ]]
}

jobs_for() {
    local threads=$1 ram_mib=$2 jobs
    jobs=$((ram_mib / 2048))
    (( jobs < 1 )) && jobs=1
    (( jobs > threads )) && jobs=$threads
    printf '%d' "$jobs"
}

minimum_root_mib() {
    [[ $1 == desktop ]] && printf 32768 || printf 12288
}

root_size_ok() {
    (( $1 >= $(minimum_root_mib "$2") * MIB ))
}

swap_limits() {
    local ram=$1 root=$2 profile=$3 recommended reserve maximum
    if (( ram <= 2048 )); then
        recommended=$((ram * 2))
    elif (( ram <= 8192 )); then
        recommended=$ram
    elif (( ram < 65536 )); then
        recommended=$ram
        (( recommended < 8192 )) && recommended=8192
        (( recommended > 16384 )) && recommended=16384
    else
        recommended=8192
    fi
    [[ $profile == desktop ]] && reserve=24576 || reserve=8192
    maximum=$((root - reserve))
    (( maximum < 0 )) && maximum=0
    (( recommended > maximum )) && recommended=$maximum
    printf '%d %d\n' "$recommended" "$maximum"
}

bounded_uint() {
    local value=$1 maximum=$2 number
    [[ $value =~ ^[0-9]+$ && ${#value} -le 18 ]] || return 1
    number=$((10#$value))
    (( number <= maximum )) || return 1
    printf '%d' "$number"
}

partition_name() {
    [[ $1 =~ [0-9]$ ]] && printf '%sp%s' "$1" "$2" || printf '%s%s' "$1" "$2"
}

confirmation_phrase() {
    case $1 in
        whole) printf 'ERASE %s' "$2" ;;
        unallocated) printf 'CREATE IN %s' "$2" ;;
        replace) printf 'FORMAT %s' "$2" ;;
        *) return 1 ;;
    esac
}

confirm_matches() {
    [[ $3 == "$(confirmation_phrase "$1" "$2")" ]]
}

ask() {
    dialog --stdout "$@"
}

ask_value() {
    local __var=$1 value
    shift
    value=$(ask "$@") || die "Installation cancelled before any target write."
    printf -v "$__var" '%s' "$value"
}

ask_yesno() {
    local status
    if dialog "$@"; then
        return 0
    else
        status=$?
    fi
    (( status == 255 )) && die "Installation cancelled before any target write."
    return 1
}

require_commands() {
    local missing=() command
    for command in dialog curl gpg gpgv sha512sum tar lsblk findmnt blockdev parted \
        wipefs mkfs.fat fsck.fat mkfs.btrfs btrfs blkid mount umount mountpoint \
        chroot swapon swapoff partprobe udevadm lspci awk sed grep od stat install \
        tee nproc paste readlink tail tr sort find mktemp cp rm mkdir chmod ln losetup xz openssl; do
        command -v "$command" >/dev/null 2>&1 || missing+=("$command")
    done
    ((${#missing[@]} == 0)) || die "Missing required live-media tools: ${missing[*]}"
}

secure_boot_is_disabled() {
    local var=/sys/firmware/efi/efivars/SecureBoot-8be4df61-93ca-11d2-aa0d-00e098032b8c value
    [[ -r $var ]] || return 1
    value=$(od -An -t u1 -j 4 -N 1 "$var" 2>/dev/null | tr -d ' ') || return 1
    [[ $value == 0 ]]
}

parent_disk() {
    local device=$1 type parent
    device=$(readlink -f -- "$device") || return 1
    while [[ -b $device ]]; do
        type=$(lsblk -dnro TYPE "$device" 2>/dev/null) || return 1
        [[ $type == disk || $type == loop ]] && { printf '%s' "$device"; return 0; }
        parent=$(lsblk -dnro PKNAME "$device" 2>/dev/null) || return 1
        parent=${parent%%$'\n'*}
        [[ -n $parent ]] || return 1
        device=/dev/$parent
    done
    return 1
}

disk_sequence() {
    local kname sequence
    kname=$(lsblk -dnro KNAME "$1") || return 1
    [[ $kname != */* && -r /sys/class/block/$kname/diskseq ]] || return 1
    read -r sequence <"/sys/class/block/$kname/diskseq" || return 1
    [[ $sequence =~ ^[0-9]+$ ]] || return 1
    printf '%s' "$sequence"
}

partition_identity() {
    local part=$1 kname parent uuid start sectors
    kname=$(lsblk -dnro KNAME "$part") || return 1
    parent=$(parent_disk "$part") || return 1
    uuid=$(lsblk -dnro PARTUUID "$part") || return 1
    [[ $kname != */* && -n $uuid ]] || return 1
    read -r start <"/sys/class/block/$kname/start" || return 1
    read -r sectors <"/sys/class/block/$kname/size" || return 1
    [[ $start =~ ^[0-9]+$ && $sectors =~ ^[0-9]+$ ]] || return 1
    printf '%s|%s|%s|%s' "$parent" "$uuid" "$start" "$sectors"
}

disk_state() {
    local disk=$1 before after bytes sector_size
    before=$(disk_sequence "$disk") || return 1
    bytes=$(blockdev --getsize64 "$disk") || return 1
    sector_size=$(blockdev --getss "$disk") || return 1
    after=$(disk_sequence "$disk") || return 1
    [[ $before == "$after" && $bytes =~ ^[0-9]+$ && $sector_size =~ ^[0-9]+$ ]] || return 1
    (( bytes > 0 && sector_size >= 512 && sector_size % 512 == 0 && MIB % sector_size == 0 )) || return 1
    printf '%s %s %s' "$before" "$bytes" "$sector_size"
}

disk_state_still_valid() {
    local state
    state=$(disk_state "$DISK") || return 1
    [[ $state == "$ORIGINAL_DISKSEQ $ORIGINAL_DISK_BYTES $ORIGINAL_SECTOR_SIZE" ]]
}

protect_loop_backing() {
    local loop=$1 depth=$2 backing source
    (( depth < 8 )) || return 1
    backing=$(losetup --noheadings --raw --output BACK-FILE "$loop" 2>/dev/null) ||
        return 1
    [[ -n $backing && $backing == /* && $backing != *$'\n'* ]] || return 1
    if [[ -b $backing ]]; then
        protect_source_disk "$backing" "$((depth + 1))"
        return
    fi
    [[ -f $backing ]] || return 1
    source=$(findmnt -n -e -T "$backing" -o SOURCE 2>/dev/null) || return 1
    [[ -n $source && $source != *$'\n'* && $source != "$loop" ]] || return 1
    protect_source_disk "$source" "$((depth + 1))"
}

protect_ancestor_rows() {
    local rows=$1 depth=$2 name type device
    local -a loops=()
    while read -r name type; do
        [[ -n $name && -n $type ]] || return 1
        case $type in
            disk)
                device=$(readlink -f -- "$name") || return 1
                PROTECTED_DISKS["$device"]=1
                ;;
            loop)
                device=$(readlink -f -- "$name") || return 1
                loops+=("$device")
                ;;
        esac
    done <<<"$rows"
    for device in "${loops[@]}"; do
        protect_loop_backing "$device" "$depth" || return 1
    done
}

protect_source_disk() {
    local source=$1 depth=${2:-0} rows
    (( depth <= 8 )) || return 1
    [[ $source == /dev/* ]] || return 0
    source=${source%%\[*}
    source=$(readlink -f -- "$source") || return 1
    [[ -b $source ]] || return 1
    rows=$(lsblk -s -nrpo NAME,TYPE "$source" 2>/dev/null) || return 1
    protect_ancestor_rows "$rows" "$depth"
}

build_protected_disks() {
    local source mounted_sources btrfs_filesystems btrfs_sources
    PROTECTED_DISKS=()
    mounted_sources=$(findmnt -rn -e -o SOURCE 2>/dev/null) || return 1
    while IFS= read -r source; do
        [[ -z $source ]] || protect_source_disk "$source" || return 1
    done <<<"$mounted_sources"
    btrfs_filesystems=$(btrfs filesystem show --all-devices --raw 2>/dev/null) || return 1
    btrfs_sources=$(awk '
        $1 == "Total" && $2 == "devices" { multi=($3 ~ /^[0-9]+$/ && $3 > 1); next }
        multi && $1 == "devid" {
            for (i=1; i<=NF; i++) if ($i == "path") {
                path=$(i+1); for (j=i+2; j<=NF; j++) path=path " " $j
                print path; break
            }
        }
    ' <<<"$btrfs_filesystems") || return 1
    while IFS= read -r source; do
        [[ -z $source ]] || protect_source_disk "$source" || return 1
    done <<<"$btrfs_sources"
}

preflight() {
    local efivar_fstype efivar_options mem_kib pci_devices
    [[ $EUID -eq 0 ]] || die "Run this installer as root (sudo ./autogentoo)."
    require_commands
    DIALOG_READY=1
    [[ -r /etc/gentoo-release ]] || die "This is not a Gentoo live environment."
    if ! mountpoint -q /run/initramfs/live && ! mountpoint -q /mnt/cdrom; then
        die "Official Gentoo minimal live media could not be proven."
    fi
    [[ -d /sys/firmware/efi ]] || die "UEFI boot was not detected; BIOS installs are unsupported."
    efivar_fstype=$(findmnt -nro FSTYPE /sys/firmware/efi/efivars 2>/dev/null) ||
        die "efivarfs could not be inspected."
    [[ $efivar_fstype == efivarfs ]] || die "efivarfs is not mounted."
    efivar_options=$(findmnt -nro OPTIONS /sys/firmware/efi/efivars 2>/dev/null) ||
        die "efivarfs mount options could not be inspected."
    [[ ,$efivar_options, != *,ro,* ]] || die "efivarfs is read-only."
    secure_boot_is_disabled || die "Secure Boot is enabled or its disabled state cannot be proven."
    [[ -r $GENTOO_KEY ]] || die "Gentoo release keys are missing: $GENTOO_KEY"
    [[ -r /usr/share/i18n/SUPPORTED ]] || die "The live media locale list is missing."
    supported_keymap us || die "The live media console keymaps are missing."
    ARCH=$(arch_name "$(uname -m)") || die "Only x86_64/amd64 and aarch64/arm64 are supported."
    CPU_THREADS=$(nproc) || die "CPU thread count could not be detected."
    mem_kib=$(awk '/^MemTotal:/ {print $2; exit}' /proc/meminfo) || die "Installed RAM could not be read."
    [[ $CPU_THREADS =~ ^[1-9][0-9]*$ && $mem_kib =~ ^[1-9][0-9]*$ ]] ||
        die "CPU or RAM information is invalid."
    RAM_MIB=$((mem_kib / 1024))
    (( RAM_MIB > 0 )) || die "Installed RAM could not be detected."
    CPU_VENDOR=$(awk -F: '/vendor_id|CPU implementer/ {gsub(/^[ \t]+/,"",$2); print $2; exit}' /proc/cpuinfo)
    pci_devices=$(lspci -nn 2>/dev/null || true)
    GPU_INFO=$(awk 'BEGIN{IGNORECASE=1} /VGA|3D controller|Display controller/ {print}' \
        <<<"$pci_devices" | paste -sd '; ' -)
    [[ -n $GPU_INFO ]] || GPU_INFO="No PCI GPU detected"
    [[ $GPU_INFO =~ [Nn][Vv][Ii][Dd][Ii][Aa] ]] && NVIDIA=1
    curl --disable --proto '=https' --tlsv1.2 --fail --silent --show-error --head \
        "https://distfiles.gentoo.org/releases/$ARCH/autobuilds/" >/dev/null ||
        die "HTTPS connectivity to Gentoo mirrors failed."
    build_protected_disks || die "Storage devices could not be enumerated safely."
    log "Preflight passed: arch=$ARCH threads=$CPU_THREADS ram=${RAM_MIB}MiB gpu=$GPU_INFO"
}

disk_has_mounts() {
    local mounts
    mounts=$(lsblk -nrpo MOUNTPOINTS "$1" 2>/dev/null) || return 0
    [[ $mounts =~ [^[:space:]] ]]
}

has_complex_signature() {
    local device=$1 reject_swap=${2:-0} fstype status
    if fstype=$(blkid -p -s TYPE -o value "$device" 2>/dev/null); then
        [[ -n $fstype ]] || return 0
    else
        status=$?
        (( status == 2 )) && return 1
        return 0
    fi
    (( reject_swap )) && [[ $fstype == swap ]] && return 0
    case $fstype in
        *_member|crypto_LUKS|BitLocker|bcache|bcachefs|ceph_bluestore|drbd|VMFS_volume|vdo)
            return 0
            ;;
    esac
    return 1
}

disk_has_complex_stack() {
    local name type ro rows first=1
    rows=$(lsblk -nrpo NAME,TYPE,RO "$1" 2>/dev/null) || return 0
    while read -r name type ro; do
        [[ $ro == 0 ]] || return 0
        if (( first )); then
            [[ $type == disk ]] || return 0
            first=0
        else
            [[ $type == part ]] || return 0
        fi
        has_complex_signature "$name" && return 0
    done <<<"$rows"
    (( first )) && return 0
    return 1
}

safe_disk() {
    local disk=$1 type ro
    disk=$(readlink -f -- "$disk") || return 1
    [[ -b $disk ]] || return 1
    type=$(lsblk -dnro TYPE "$disk") || return 1
    ro=$(lsblk -dnro RO "$disk") || return 1
    [[ $type == disk && $ro == 0 ]] || return 1
    [[ -z ${PROTECTED_DISKS[$disk]:-} ]] || return 1
    ! disk_has_mounts "$disk" || return 1
    ! disk_has_complex_stack "$disk" || return 1
}

disk_menu() {
    local disk type size model devices state sequence bytes sector_size
    devices=$(lsblk -dnpo NAME,TYPE 2>/dev/null) || return 1
    while read -r disk type; do
        [[ $type == disk ]] || continue
        safe_disk "$disk" || continue
        state=$(disk_state "$disk") || continue
        read -r sequence bytes sector_size <<<"$state"
        size=$(lsblk -dnro SIZE "$disk") || continue
        model=$(lsblk -dnro MODEL "$disk" 2>/dev/null) || model=""
        model=${model%%$'\n'*}
        model=$(printf '%s' "$model" | tr -cd '[:print:]') || model=""
        model=${model%${model##*[![:space:]]}}
        printf '%s\t%s %s\t%s\t%s\t%s\n' "$disk" "$size" "${model:-disk}" \
            "$sequence" "$bytes" "$sector_size"
    done <<<"$devices"
}

disk_is_gpt() {
    local table label
    table=$(parted -sm "$1" print 2>/dev/null) || return 1
    label=$(awk -F: 'NR==2 {print $6}' <<<"$table") || return 1
    [[ $label == gpt ]]
}

parted_rows() {
    local table rows
    table=$(parted -sm "$1" unit s print 2>/dev/null) || return 1
    rows=$(awk -F: '$1 ~ /^[0-9]+$/ {print}' <<<"$table") || return 1
    [[ -z $rows ]] || printf '%s\n' "$rows"
}

free_extents() {
    local table extents
    table=$(parted -sm "$1" unit s print free 2>/dev/null) || return 1
    extents=$(awk -F: 'tolower($5) ~ /free/ {
        gsub(/s/,"",$2); gsub(/s/,"",$3); gsub(/s/,"",$4); print $2, $3, $4
    }' <<<"$table") || return 1
    [[ -z $extents ]] || printf '%s\n' "$extents"
}

aligned_extent() {
    local start=$1 end=$2 sector_size=$3 alignment
    (( MIB % sector_size == 0 )) || return 1
    alignment=$((MIB / sector_size))
    start=$(((start + alignment - 1) / alignment * alignment))
    end=$(((end + 1) / alignment * alignment - 1))
    (( end >= start )) || return 1
    printf '%d %d %d\n' "$start" "$end" "$((end - start + 1))"
}

fat_free_bytes_from_fsck() {
    local values cluster used total
    values=$(awk '
        NF == 4 && $1 ~ /^[0-9]+$/ && $2 == "bytes" &&
            $3 == "per" && $4 == "cluster" { cluster=$1 }
        $NF == "clusters" {
            split($(NF - 1), counts, "/")
            if (counts[1] ~ /^[0-9]+$/ && counts[2] ~ /^[0-9]+$/) {
                used=counts[1]
                total=counts[2]
            }
        }
        END {
            if (cluster ~ /^[0-9]+$/ && used ~ /^[0-9]+$/ &&
                total ~ /^[0-9]+$/) print cluster, used, total
            else exit 1
        }
    ') || return 1
    read -r cluster used total <<<"$values"
    [[ $cluster =~ ^[0-9]+$ && $used =~ ^[0-9]+$ && $total =~ ^[0-9]+$ ]] ||
        return 1
    (( cluster > 0 && cluster <= MIB && total <= 4294967295 && total >= used )) ||
        return 1
    printf '%d\n' "$(((total - used) * cluster))"
}

esp_free_bytes() {
    local output free bytes
    output=$(LC_ALL=C fsck.fat -n -v "$1" 2>&1) || return 1
    free=$(fat_free_bytes_from_fsck <<<"$output") || return 1
    bytes=$(blockdev --getsize64 "$1" 2>/dev/null) || return 1
    [[ $bytes =~ ^[0-9]+$ ]] && (( free <= bytes )) || return 1
    printf '%s\n' "$free"
}

is_fat32() {
    local device=$1 fstype version
    fstype=$(blkid -p -s TYPE -o value "$device" 2>/dev/null) || return 1
    version=$(blkid -p -s VERSION -o value "$device" 2>/dev/null) || return 1
    [[ $fstype == vfat && $version == FAT32 ]]
}

is_reusable_esp() {
    local part=$1 device_type type free mounts
    [[ -b $part ]] || return 1
    device_type=$(lsblk -dnro TYPE "$part") || return 1
    [[ $device_type == part ]] || return 1
    mounts=$(lsblk -nro MOUNTPOINTS "$part" 2>/dev/null) || return 1
    [[ ! $mounts =~ [^[:space:]] ]] || return 1
    [[ $(blockdev --getro "$part" 2>/dev/null) == 0 ]] || return 1
    if [[ -n ${2:-} ]]; then
        type=$2
    else
        type=$(lsblk -dnro PARTTYPE "$part") || return 1
    fi
    [[ ${type,,} == "$ESP_GUID" ]] && is_fat32 "$part" || return 1
    free=$(esp_free_bytes "$part") || return 1
    [[ $free =~ ^[0-9]+$ ]] && (( free >= 32 * MIB ))
}

esp_menu() {
    local disk=$1 part type size free identity partitions
    partitions=$(lsblk -nrpo NAME,PARTTYPE,TYPE "$disk" 2>/dev/null) || return 1
    partitions=$(awk '$3=="part" {print $1 "\t" $2}' <<<"$partitions") || return 1
    while IFS=$'\t' read -r part type; do
        [[ -n $part ]] || continue
        is_reusable_esp "$part" "$type" || continue
        size=$(lsblk -dnro SIZE "$part") || continue
        free=$(esp_free_bytes "$part") || continue
        identity=$(partition_identity "$part") || continue
        printf '%s\t%s, %d MiB free\t%s\n' "$part" "$size" "$((free / MIB))" "$identity"
    done <<<"$partitions"
}

describe_partitions() {
    local disk=$1 excluded=${2:-} table rows
    table=$(parted_rows "$disk") || return 1
    rows=$(awk -F: -v excluded="$excluded" \
        '$1 != excluded {printf "  #%s %s-%s %s %s\n",$1,$2,$3,$4,$6}' <<<"$table") || return 1
    printf '%s' "${rows:-  (none)}"
}

collect_profile() {
    if [[ $ARCH == amd64 ]]; then
        ask_value PROFILE --title "Installation profile" --default-item desktop --menu \
            "Choose an OpenRC profile:" 12 72 2 \
            desktop "OpenRC + Hyprland workstation (default)" \
            base "OpenRC base system"
        if [[ $PROFILE == desktop && $NVIDIA == 1 ]]; then
            if ask_yesno --title "NVIDIA confirmation required" --yesno \
                "Hyprland is supported here only with Turing / GTX 1650 or newer NVIDIA hardware.\n\nConfirm that every NVIDIA GPU to be used meets that requirement. Hybrid graphics remains best-effort." 14 72; then
                NVIDIA_CONFIRMED=1
            else
                PROFILE=base
                dialog_message "The workstation profile was blocked. The base profile remains available."
            fi
        fi
    else
        PROFILE=base
        dialog_message "arm64 installs the generic UEFI/SBSA OpenRC base profile."
    fi
    if [[ $PROFILE == desktop ]]; then
        ask_value DISPLAY_MANAGER --title "Display manager" --default-item sddm --menu \
            "Choose the login manager:" 12 70 2 \
            sddm "SDDM (default; X11 greeter, native Wayland session)" \
            ly "Ly TUI greeter on dedicated TTY 2"
    fi
}

prompt_validated() {
    local __var=$1 validator=$2 title=$3 prompt=$4 default=$5 value
    while :; do
        ask_value value --title "$title" --inputbox "$prompt" 10 72 "$default"
        if "$validator" "$value"; then
            printf -v "$__var" '%s' "$value"
            return
        fi
        dialog_message "Invalid value. Please try again."
    done
}

valid_password_hash() {
    [[ $1 =~ ^\$6\$[./A-Za-z0-9]{1,16}\$[./A-Za-z0-9]{86}$ ]]
}

hash_password() {
    local hash
    hash=$(printf '%s' "$1" | openssl passwd -6 -stdin 2>/dev/null) || return 1
    valid_password_hash "$hash" || return 1
    printf '%s\n' "$hash"
}

collect_password_hash() {
    local password confirm hash
    while :; do
        password=$(ask --title "User password" --insecure --passwordbox \
            "Password for $USERNAME (minimum 8 characters):" 10 72) || return 1
        ((${#password} >= 8)) || {
            dialog_message "Use at least 8 characters."
            continue
        }
        confirm=$(ask --title "Confirm password" --insecure --passwordbox \
            "Repeat the password for $USERNAME:" 10 72) || return 1
        [[ $password == "$confirm" ]] && break
        dialog_message "Passwords did not match."
    done
    hash=$(hash_password "$password") || return 1
    unset password confirm
    printf '%s\n' "$hash"
}

collect_identity() {
    prompt_validated LOCALE supported_locale "Locale" "Supported UTF-8 locale (for example en_US.UTF-8):" "$LOCALE"
    while :; do
        ask_value TIMEZONE --title "Timezone" --inputbox "Timezone (for example Europe/Berlin):" 10 72 "$TIMEZONE"
        valid_timezone "$TIMEZONE" && break
        dialog_message "That timezone is not present on the live media."
    done
    prompt_validated KEYMAP supported_keymap "Console keymap" "Console keymap:" "$KEYMAP"
    if [[ $PROFILE == desktop ]]; then
        prompt_validated XKB_LAYOUT valid_layout "Keyboard layout" "XKB layout for Hyprland:" "$XKB_LAYOUT"
    fi
    prompt_validated HOSTNAME valid_hostname "Hostname" "Hostname:" "$HOSTNAME"
    prompt_validated USERNAME available_username "User" "New login name (wheel and video groups):" "user"
    if (( DRY_RUN )); then
        USER_PASSWORD_HASH=""
        ROOT_SAME_PASSWORD=0
        return
    fi
    USER_PASSWORD_HASH=$(collect_password_hash) ||
        die "Password entry was cancelled or could not be hashed safely."
    if ask_yesno --title "Root account" --defaultno --yesno \
        "Set root to the same password as $USERNAME?\n\nNo keeps root locked; wheel can use sudo." 11 72; then
        ROOT_SAME_PASSWORD=1
    else
        ROOT_SAME_PASSWORD=0
    fi
}

choose_safe_disk() {
    local __var=$1 title=$2 rows=() menu disk description sequence bytes sector_size selected
    local -A sequences=() byte_sizes=() sector_sizes=()
    build_protected_disks || die "Storage devices could not be enumerated safely."
    menu=$(disk_menu) || die "Storage devices could not be enumerated safely."
    while IFS=$'\t' read -r disk description sequence bytes sector_size; do
        [[ -n $disk ]] || continue
        rows+=("$disk" "$description")
        sequences["$disk"]=$sequence
        byte_sizes["$disk"]=$bytes
        sector_sizes["$disk"]=$sector_size
    done <<<"$menu"
    ((${#rows[@]})) || die "No unmounted, writable, non-live, plain disks are available."
    ask_value "$__var" --title "$title" --menu "Select a target disk:" 18 78 10 "${rows[@]}"
    selected=${!__var}
    ORIGINAL_DISKSEQ=${sequences[$selected]:-}
    ORIGINAL_DISK_BYTES=${byte_sizes[$selected]:-0}
    ORIGINAL_SECTOR_SIZE=${sector_sizes[$selected]:-0}
    SECTOR_SIZE=$ORIGINAL_SECTOR_SIZE
    build_protected_disks || die "Storage devices could not be enumerated safely."
    disk_state_still_valid && safe_disk "$selected" ||
        die "The selected disk changed while the menu was open."
}

plan_whole_layout() {
    GAP_START=$((MIB / SECTOR_SIZE))
    ROOT_START=$((GAP_START + GIB / SECTOR_SIZE))
    ROOT_END=$((ORIGINAL_DISK_BYTES / SECTOR_SIZE - (16384 + SECTOR_SIZE - 1) / SECTOR_SIZE - 2))
    ROOT_BYTES=$(((ROOT_END - ROOT_START + 1) * SECTOR_SIZE))
    ORIGINAL_ROOT_BYTES=$ROOT_BYTES
}

choose_whole_disk() {
    MODE=whole
    choose_safe_disk DISK "Erase a whole disk"
    plan_whole_layout
    ESP_ACTION=create
    ESP_PART=$(partition_name "$DISK" 1)
    ROOT_PART=$(partition_name "$DISK" 2)
    PRESERVED="None; the entire GPT and all signatures will be erased."
}

choose_esp() {
    local disk=$1 required=$2 rows=() part description identity menu
    local -A identities=()
    build_protected_disks || die "Storage devices could not be enumerated safely."
    menu=$(esp_menu "$disk") || die "EFI System Partitions could not be enumerated safely."
    while IFS=$'\t' read -r part description identity; do
        [[ -n $part ]] || continue
        rows+=("$part" "$description")
        identities["$part"]=$identity
    done <<<"$menu"
    if ((${#rows[@]} == 0)); then
        [[ $required == allow-create ]] || die "No same-disk FAT ESP with at least 32 MiB free is reusable."
        ESP_ACTION=create
        ESP_PART="(new 1 GiB ESP)"
        ORIGINAL_ESP_ID=""
        return
    fi
    if [[ $required == allow-create ]]; then
        rows+=("CREATE" "Create a new 1 GiB ESP in the selected gap")
    fi
    ask_value part --title "EFI System Partition" --menu \
        "Reuse a same-disk ESP without formatting, or create one:" 18 78 10 "${rows[@]}"
    if [[ $part == CREATE ]]; then
        ESP_ACTION=create
        ESP_PART="(new 1 GiB ESP)"
        ORIGINAL_ESP_ID=""
    else
        ESP_ACTION=reuse
        ESP_PART=$part
        ORIGINAL_ESP_ID=${identities[$part]:-}
        build_protected_disks || die "Storage devices could not be enumerated safely."
        disk_state_still_valid && is_reusable_esp "$ESP_PART" &&
            [[ $(partition_identity "$ESP_PART") == "$ORIGINAL_ESP_ID" ]] ||
            die "The selected EFI System Partition changed while the menu was open."
    fi
}

choose_unallocated() {
    local min_mib min_bytes esp_sectors required_sectors start end sectors rows=() label choice extents aligned
    MODE=unallocated
    choose_safe_disk DISK "Use unallocated disk space"
    disk_is_gpt "$DISK" || die "Coexistence requires an existing GPT disk label."
    choose_esp "$DISK" allow-create
    min_mib=$(minimum_root_mib "$PROFILE")
    min_bytes=$((min_mib * MIB))
    esp_sectors=0
    [[ $ESP_ACTION == create ]] && esp_sectors=$((GIB / SECTOR_SIZE))
    required_sectors=$(( (min_bytes + SECTOR_SIZE - 1) / SECTOR_SIZE + esp_sectors ))
    extents=$(free_extents "$DISK") || die "Unallocated space could not be enumerated safely."
    while read -r start end sectors; do
        aligned=$(aligned_extent "$start" "$end" "$SECTOR_SIZE") || continue
        read -r start end sectors <<<"$aligned"
        (( sectors >= required_sectors )) || continue
        label="sectors $start-$end ($((sectors * SECTOR_SIZE / MIB)) MiB)"
        rows+=("$start:$end" "$label")
    done <<<"$extents"
    ((${#rows[@]})) || die "No unallocated extent can hold the selected profile and ESP plan."
    ask_value choice --title "Unallocated extent" --menu \
        "No neighboring partition will be resized. Choose one aligned usable range:" 18 78 10 "${rows[@]}"
    GAP_START=${choice%:*}
    GAP_END=${choice#*:}
    ROOT_START=$((GAP_START + esp_sectors))
    ROOT_END=$GAP_END
    ROOT_BYTES=$(((ROOT_END - ROOT_START + 1) * SECTOR_SIZE))
    ORIGINAL_ROOT_BYTES=$ROOT_BYTES
    ROOT_PART="(new partition)"
    PRESERVED=$(describe_partitions "$DISK") || die "The preserved partition list could not be read safely."
}

ordinary_linux_partition() {
    local part=$1 type parent mounts ro
    [[ -b $part ]] || return 1
    type=$(lsblk -dnro TYPE "$part") || return 1
    [[ $type == part ]] || return 1
    mounts=$(lsblk -nro MOUNTPOINTS "$part" 2>/dev/null) || return 1
    [[ ! $mounts =~ [^[:space:]] ]] || return 1
    ro=$(blockdev --getro "$part" 2>/dev/null) || return 1
    [[ $ro == 0 ]] || return 1
    type=$(lsblk -dnro PARTTYPE "$part")
    [[ ${type,,} == "$LINUX_GUID" ]] || return 1
    has_complex_signature "$part" 1 && return 1
    parent=$(parent_disk "$part" 2>/dev/null) || return 1
    safe_disk "$parent"
}

replace_menu() {
    local disks disk disk_type state sequence bytes sector_size esp_options partitions
    local part part_type size fstype root_identity root_bytes final_state
    disks=$(lsblk -dnpo NAME,TYPE 2>/dev/null) || return 1
    while read -r disk disk_type; do
        [[ $disk_type == disk ]] || continue
        safe_disk "$disk" || continue
        disk_is_gpt "$disk" || continue
        state=$(disk_state "$disk") || continue
        read -r sequence bytes sector_size <<<"$state"
        esp_options=$(esp_menu "$disk") || return 1
        [[ -n $esp_options ]] || continue
        partitions=$(lsblk -nrpo NAME,TYPE "$disk" 2>/dev/null) || return 1
        while read -r part part_type; do
            [[ $part_type == part ]] || continue
            ordinary_linux_partition "$part" || continue
            size=$(lsblk -dnro SIZE "$part") || continue
            root_bytes=$(blockdev --getsize64 "$part") || continue
            root_identity=$(partition_identity "$part") || continue
            fstype=$(blkid -p -s TYPE -o value "$part" 2>/dev/null || true)
            printf '%s\t%s on %s (%s)\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "$part" "$size" "$disk" "${fstype:-unknown filesystem}" "$disk" \
                "$sequence" "$bytes" "$sector_size" "$root_identity" "$root_bytes"
        done <<<"$partitions"
        final_state=$(disk_state "$disk") || return 1
        [[ $final_state == "$state" ]] || return 1
    done <<<"$disks"
}

choose_replace() {
    local rows=() menu part description disk sequence bytes sector_size root_identity root_bytes min_mib part_number
    local -A disks=() sequences=() byte_sizes=() sector_sizes=() root_ids=() root_byte_sizes=()
    MODE=replace
    build_protected_disks || die "Storage devices could not be enumerated safely."
    menu=$(replace_menu) || die "Replaceable partitions could not be enumerated safely."
    while IFS=$'\t' read -r part description disk sequence bytes sector_size root_identity root_bytes; do
        [[ -n $part ]] || continue
        rows+=("$part" "$description")
        disks["$part"]=$disk
        sequences["$part"]=$sequence
        byte_sizes["$part"]=$bytes
        sector_sizes["$part"]=$sector_size
        root_ids["$part"]=$root_identity
        root_byte_sizes["$part"]=$root_bytes
    done <<<"$menu"
    ((${#rows[@]})) || die "No safe ordinary Linux partition with a reusable same-disk ESP is available."
    ask_value ROOT_PART --title "Replace one partition" --menu \
        "Only the selected partition will be formatted as Btrfs:" 18 78 10 "${rows[@]}"
    DISK=${disks[$ROOT_PART]:-}
    ORIGINAL_DISKSEQ=${sequences[$ROOT_PART]:-}
    ORIGINAL_DISK_BYTES=${byte_sizes[$ROOT_PART]:-0}
    ORIGINAL_SECTOR_SIZE=${sector_sizes[$ROOT_PART]:-0}
    SECTOR_SIZE=$ORIGINAL_SECTOR_SIZE
    ORIGINAL_ROOT_ID=${root_ids[$ROOT_PART]:-}
    ROOT_BYTES=${root_byte_sizes[$ROOT_PART]:-0}
    ORIGINAL_ROOT_BYTES=$ROOT_BYTES
    build_protected_disks || die "Storage devices could not be enumerated safely."
    disk_state_still_valid && ordinary_linux_partition "$ROOT_PART" &&
        [[ $(partition_identity "$ROOT_PART") == "$ORIGINAL_ROOT_ID" ]] &&
        [[ $(blockdev --getsize64 "$ROOT_PART") == "$ORIGINAL_ROOT_BYTES" ]] ||
        die "The selected root partition changed while the menu was open."
    min_mib=$(minimum_root_mib "$PROFILE")
    root_size_ok "$ROOT_BYTES" "$PROFILE" || die "The selected root partition is smaller than ${min_mib} MiB."
    choose_esp "$DISK" must-reuse
    part_number=$(lsblk -dnro PARTN "$ROOT_PART") || die "The root partition number could not be read."
    PRESERVED=$(describe_partitions "$DISK" "$part_number") ||
        die "The preserved partition list could not be read safely."
}

collect_storage() {
    ORIGINAL_ROOT_ID=""
    ORIGINAL_ESP_ID=""
    ask_value MODE --title "Storage workflow" --default-item whole --menu \
        "Choose how target storage is allocated:" 15 78 3 \
        whole "Erase one whole non-live disk" \
        unallocated "Consume one existing GPT free extent; never resize" \
        replace "Format one ordinary Linux partition; reuse its ESP"
    case $MODE in
        whole) choose_whole_disk ;;
        unallocated) choose_unallocated ;;
        replace) choose_replace ;;
    esac
    local min_mib
    min_mib=$(minimum_root_mib "$PROFILE")
    root_size_ok "$ROOT_BYTES" "$PROFILE" || die "Root must be at least ${min_mib} MiB for this profile."
    storage_plan_still_valid || die "Storage changed while the installation plan was being built."
}

collect_swap() {
    local recommended maximum value normalized root_mib=$((ROOT_BYTES / MIB))
    read -r recommended maximum < <(swap_limits "$RAM_MIB" "$root_mib" "$PROFILE")
    while :; do
        ask_value value --title "Swap file" --inputbox \
            "Non-hibernation Btrfs swap in MiB.\nRecommended: $recommended MiB\nAllowed: 0-$maximum MiB\n\nThe cap preserves build and base-system space." \
            14 72 "$recommended"
        if normalized=$(bounded_uint "$value" "$maximum"); then
            SWAP_MIB=$normalized
            return
        fi
        dialog_message "Enter a whole number from 0 through $maximum."
    done
}

target_has_mounts() {
    local mount mounts
    mounts=$(findmnt -rn -o TARGET 2>/dev/null) || return 0
    while IFS= read -r mount; do
        [[ $mount == "$TARGET" || $mount == "$TARGET/"* ]] && return 0
    done <<<"$mounts"
    return 1
}

storage_plan_still_valid() {
    local start end sectors found=0 extents root_size
    [[ ! -e $TARGET || ( -d $TARGET && ! -L $TARGET ) ]] || return 1
    ! target_has_mounts || return 1
    build_protected_disks || return 1
    safe_disk "$DISK" || return 1
    disk_state_still_valid || return 1
    case $MODE in
        whole) ;;
        unallocated)
            disk_is_gpt "$DISK" || return 1
            extents=$(free_extents "$DISK") || return 1
            while read -r start end sectors; do
                (( start <= GAP_START && end >= GAP_END )) && found=1
            done <<<"$extents"
            (( found )) || return 1
            [[ $ESP_ACTION == create ]] || {
                is_reusable_esp "$ESP_PART" &&
                    [[ $(partition_identity "$ESP_PART") == "$ORIGINAL_ESP_ID" ]]
            }
            ;;
        replace)
            root_size=$(blockdev --getsize64 "$ROOT_PART") || return 1
            ordinary_linux_partition "$ROOT_PART" &&
                [[ $root_size == "$ORIGINAL_ROOT_BYTES" ]] &&
                [[ $(partition_identity "$ROOT_PART") == "$ORIGINAL_ROOT_ID" ]] &&
                is_reusable_esp "$ESP_PART" &&
                [[ $(partition_identity "$ESP_PART") == "$ORIGINAL_ESP_ID" ]]
            ;;
        *) return 1 ;;
    esac
}

plan_summary() {
    local root_target=$ROOT_PART esp_text gpu_note="" part_number row table
    if [[ $MODE == whole ]]; then
        root_target="$ROOT_PART (new), sectors $ROOT_START-$ROOT_END"
    elif [[ $MODE == replace ]]; then
        part_number=$(lsblk -dnro PARTN "$ROOT_PART") || return 1
        table=$(parted_rows "$DISK") || return 1
        row=$(awk -F: -v n="$part_number" '$1==n {print $2 "-" $3; exit}' <<<"$table") || return 1
        [[ -n $row ]] || return 1
        root_target="$ROOT_PART, sectors $row"
    fi
    [[ $MODE == unallocated ]] && root_target="new partition, sectors $ROOT_START-$ROOT_END"
    if [[ $ESP_ACTION == create ]]; then
        esp_text="create and format 1 GiB FAT32 ESP, sectors $GAP_START-$((ROOT_START - 1))"
    else
        esp_text="reuse $ESP_PART; never format"
    fi
    (( NVIDIA )) && gpu_note=$'\nNVIDIA: user-confirmed Turing-or-newer='"$NVIDIA_CONFIRMED"$'; hybrid support is best-effort'
    cat <<EOF
Architecture: $ARCH UEFI / OpenRC
Profile: $PROFILE$([[ $PROFILE == desktop ]] && printf '; display manager: %s' "$DISPLAY_MANAGER")
Target disk: $DISK
Storage mode: $MODE
Root: $root_target
Root size: $((ROOT_BYTES / MIB)) MiB, Btrfs @ and @home
ESP: $esp_text
Swap: $SWAP_MIB MiB in separate @swap subvolume
Hostname/user: $HOSTNAME / $USERNAME
Locale/timezone: $LOCALE / $TIMEZONE
CPU: $CPU_THREADS threads, $RAM_MIB MiB RAM
GPU: $GPU_INFO$gpu_note

Preserved partition table entries:
$PRESERVED
EOF
}

review_and_confirm() {
    local summary phrase entered
    summary=$(plan_summary)
    dialog --title "Final installation plan" --scrollbar --msgbox "$summary" 24 90 ||
        die "Installation cancelled before any target write."
    if (( DRY_RUN )); then
        dialog_message "Dry run complete. No download, mount, format, partition, or chroot action was executed.\n\nLog: $LOG"
        log "Dry run completed with zero target writes"
        return 0
    fi
    phrase=$(confirmation_phrase "$MODE" "$([[ $MODE == replace ]] && printf '%s' "$ROOT_PART" || printf '%s' "$DISK")")
    ask_value entered --title "Destructive confirmation" --inputbox \
        "Review the plan carefully. Type exactly:\n\n$phrase" 12 78
    confirm_matches "$MODE" "$([[ $MODE == replace ]] && printf '%s' "$ROOT_PART" || printf '%s' "$DISK")" "$entered" ||
        die "Confirmation did not match; no target write was made."
    storage_plan_still_valid || die "Storage changed after planning; no target write was made."
}

part_number_at_start() {
    local disk=$1 wanted=$2 number start table
    table=$(parted_rows "$disk") || return 1
    while IFS=: read -r number start _; do
        start=${start%s}
        [[ $start == "$wanted" ]] && { printf '%s' "$number"; return 0; }
    done <<<"$table"
    return 1
}

settle_partitions() {
    run partprobe "$1"
    run udevadm settle
}

planned_partition_matches() {
    local part=$1 expected_start=$2 expected_end=$3 expected_guid=$4
    local identity parent uuid actual_start actual_sectors type ro mounts topology scale
    [[ $expected_start =~ ^[0-9]+$ && $expected_end =~ ^[0-9]+$ ]] || return 1
    (( expected_end >= expected_start && SECTOR_SIZE % 512 == 0 )) || return 1
    identity=$(partition_identity "$part") || return 1
    IFS='|' read -r parent uuid actual_start actual_sectors <<<"$identity"
    [[ $parent == "$DISK" && -n $uuid ]] || return 1
    type=$(lsblk -dnro PARTTYPE "$part") || return 1
    [[ ${type,,} == "$expected_guid" ]] || return 1
    ro=$(blockdev --getro "$part" 2>/dev/null) || return 1
    [[ $ro == 0 ]] || return 1
    mounts=$(lsblk -nro MOUNTPOINTS "$part" 2>/dev/null) || return 1
    [[ ! $mounts =~ [^[:space:]] ]] || return 1
    topology=$(lsblk -nrpo TYPE "$part" 2>/dev/null) || return 1
    [[ $topology == part ]] || return 1
    scale=$((SECTOR_SIZE / 512))
    (( actual_start == expected_start * scale &&
        actual_sectors == (expected_end - expected_start + 1) * scale ))
}

partition_matches_identity() {
    local part=$1 expected_identity=$2 expected_guid=$3 identity parent uuid start sectors type ro mounts topology
    identity=$(partition_identity "$part") || return 1
    [[ $identity == "$expected_identity" ]] || return 1
    IFS='|' read -r parent uuid start sectors <<<"$identity"
    [[ $parent == "$DISK" && -n $uuid ]] || return 1
    type=$(lsblk -dnro TYPE "$part") || return 1
    [[ $type == part ]] || return 1
    type=$(lsblk -dnro PARTTYPE "$part") || return 1
    [[ ${type,,} == "$expected_guid" ]] || return 1
    ro=$(blockdev --getro "$part" 2>/dev/null) || return 1
    [[ $ro == 0 ]] || return 1
    mounts=$(lsblk -nro MOUNTPOINTS "$part" 2>/dev/null) || return 1
    [[ ! $mounts =~ [^[:space:]] ]] || return 1
    topology=$(lsblk -nrpo TYPE "$part" 2>/dev/null) || return 1
    [[ $topology == part ]]
}

ordinary_partition_matches_identity() {
    local part=$1 expected_identity=$2
    partition_matches_identity "$part" "$expected_identity" "$LINUX_GUID" || return 1
    ! has_complex_signature "$part" 1
}

format_targets_still_valid() {
    local disk_ro root_size
    disk_state_still_valid || return 1
    build_protected_disks || return 1
    [[ -z ${PROTECTED_DISKS[$DISK]:-} ]] || return 1
    disk_ro=$(blockdev --getro "$DISK" 2>/dev/null) || return 1
    [[ $disk_ro == 0 ]] || return 1
    ! disk_has_mounts "$DISK" || return 1
    [[ $ROOT_PART != "$ESP_PART" ]] || return 1
    case $MODE in
        whole|unallocated)
            planned_partition_matches "$ROOT_PART" "$ROOT_START" "$ROOT_END" "$LINUX_GUID" || return 1
            if [[ $ESP_ACTION == create ]]; then
                planned_partition_matches "$ESP_PART" "$GAP_START" "$((ROOT_START - 1))" "$ESP_GUID"
            else
                is_reusable_esp "$ESP_PART" &&
                    [[ $(partition_identity "$ESP_PART") == "$ORIGINAL_ESP_ID" ]]
            fi
            ;;
        replace)
            root_size=$(blockdev --getsize64 "$ROOT_PART") || return 1
            ordinary_partition_matches_identity "$ROOT_PART" "$ORIGINAL_ROOT_ID" &&
                [[ $root_size == "$ORIGINAL_ROOT_BYTES" ]] &&
                partition_matches_identity "$ESP_PART" "$ORIGINAL_ESP_ID" "$ESP_GUID" &&
                is_reusable_esp "$ESP_PART" &&
                [[ $(partition_identity "$ESP_PART") == "$ORIGINAL_ESP_ID" ]]
            ;;
        *) return 1 ;;
    esac
}

setup_storage() {
    local number esp_end
    case $MODE in
        whole)
            run wipefs -af "$DISK"
            run parted -s -a none "$DISK" mklabel gpt
            run parted -s -a none "$DISK" unit s mkpart "Gentoo ESP" fat32 "${GAP_START}s" "$((ROOT_START - 1))s"
            run parted -s "$DISK" set 1 esp on
            run parted -s -a none "$DISK" unit s mkpart "Gentoo root" btrfs "${ROOT_START}s" "${ROOT_END}s"
            settle_partitions "$DISK"
            ESP_PART=$(partition_name "$DISK" 1)
            ROOT_PART=$(partition_name "$DISK" 2)
            ;;
        unallocated)
            if [[ $ESP_ACTION == create ]]; then
                esp_end=$((ROOT_START - 1))
                run parted -s -a none "$DISK" unit s mkpart "Gentoo ESP" fat32 "${GAP_START}s" "${esp_end}s"
                settle_partitions "$DISK"
                number=$(part_number_at_start "$DISK" "$GAP_START") ||
                    die "The new EFI System Partition could not be identified."
                ESP_PART=$(partition_name "$DISK" "$number")
                run parted -s "$DISK" set "$number" esp on
            fi
            run parted -s -a none "$DISK" unit s mkpart "Gentoo root" btrfs "${ROOT_START}s" "${ROOT_END}s"
            settle_partitions "$DISK"
            number=$(part_number_at_start "$DISK" "$ROOT_START") ||
                die "The new root partition could not be identified."
            ROOT_PART=$(partition_name "$DISK" "$number")
            ;;
        replace) ;;
    esac
    [[ -b $ROOT_PART ]] || die "The new root partition did not appear."
    [[ -b $ESP_PART ]] || die "The EFI System Partition did not appear."
    format_targets_still_valid || die "Created storage no longer matches the confirmed plan; formatting was stopped."
    if [[ $ESP_ACTION == create ]]; then
        run wipefs -af "$ESP_PART"
        run mkfs.fat -F 32 -n GENTOOEFI "$ESP_PART"
    fi
    run wipefs -af "$ROOT_PART"
    run mkfs.btrfs -f -L Gentoo "$ROOT_PART"
}

mount_layout() {
    run mkdir -p "$TARGET"
    TARGET_ACTIVE=1
    run mount -o noatime,compress=zstd:1 "$ROOT_PART" "$TARGET"
    run btrfs subvolume create "$TARGET/@"
    run btrfs subvolume create "$TARGET/@home"
    (( SWAP_MIB == 0 )) || run btrfs subvolume create "$TARGET/@swap"
    run umount "$TARGET"
    TARGET_ACTIVE=0
    TARGET_ACTIVE=1
    run mount -o noatime,compress=zstd:1,subvol=@ "$ROOT_PART" "$TARGET"
    run mkdir -p "$TARGET/home" "$TARGET/efi"
    run mount -o noatime,compress=zstd:1,subvol=@home "$ROOT_PART" "$TARGET/home"
    if (( SWAP_MIB )); then
        run mkdir -p "$TARGET/.swap"
        run mount -o noatime,compress=zstd:1,subvol=@swap "$ROOT_PART" "$TARGET/.swap"
        OUR_SWAP="$TARGET/.swap/swapfile"
        run btrfs filesystem mkswapfile --size "${SWAP_MIB}m" "$OUR_SWAP"
        run swapon "$OUR_SWAP"
    fi
    run mount -o umask=0077,nodev,nosuid,noexec "$ESP_PART" "$TARGET/efi"
}

stage_pointer_entry() {
    local stage=$1 entry=$2 path size extra timestamp filename
    read -r path size extra <<<"$entry" || return 1
    timestamp=${path%%/*}
    filename=${path#*/}
    [[ -z ${extra:-} && $timestamp =~ ^[0-9]{8}T[0-9]{6}Z$ &&
        $filename == "$stage-$timestamp.tar.xz" && $size =~ ^[1-9][0-9]*$ &&
        ${#size} -le 18 ]] || return 1
    printf '%s %s\n' "$path" "$size"
}

sha512_digest() {
    awk -v file="$2" '
        $0 == "# SHA512 HASH" { section=1; next }
        /^#/ { section=0 }
        section && $2 == file { print $1; exit }
    ' "$1"
}

stage_pointer_url() {
    local stage
    [[ $PROFILE == desktop ]] && stage=stage3-amd64-desktop-openrc || stage=stage3-$ARCH-openrc
    printf 'https://distfiles.gentoo.org/releases/%s/autobuilds/latest-%s.txt' "$ARCH" "$stage"
}

prepare_stage_metadata() {
    local pointer_url stage entry filename keyring verified_pointer verified_digests
    WORKDIR=$(mktemp -d /tmp/autogentoo-metadata.XXXXXX)
    pointer_url=$(stage_pointer_url)
    stage=${pointer_url##*/latest-}
    stage=${stage%.txt}
    keyring="$WORKDIR/gentoo-release.gpg"
    verified_pointer="$WORKDIR/latest.verified"
    run gpg --no-options --batch --yes --dearmor --output "$keyring" "$GENTOO_KEY"
    run curl --disable --proto '=https' --proto-redir '=https' --tlsv1.2 --fail --location \
        --show-error --remove-on-error --max-filesize "$MIB" \
        --output "$WORKDIR/latest.txt" "$pointer_url"
    run gpgv --homedir "$WORKDIR" --output "$verified_pointer" --keyring "$keyring" \
        "$WORKDIR/latest.txt"
    entry=$(awk 'NF == 2 && $1 ~ /\.tar\.xz$/ && $2 ~ /^[0-9]+$/ {print; exit}' \
        "$verified_pointer")
    entry=$(stage_pointer_entry "$stage" "$entry") ||
        die "The signed stage pointer did not name the expected $stage archive."
    read -r STAGE_PATH STAGE_SIZE <<<"$entry"
    filename=${STAGE_PATH##*/}
    STAGE_BASE="https://distfiles.gentoo.org/releases/$ARCH/autobuilds/$STAGE_PATH"
    run curl --disable --proto '=https' --proto-redir '=https' --tlsv1.2 --fail --location \
        --show-error --remove-on-error --max-filesize "$MIB" \
        --output "$WORKDIR/$filename.asc" "$STAGE_BASE.asc"
    run curl --disable --proto '=https' --proto-redir '=https' --tlsv1.2 --fail --location \
        --show-error --remove-on-error --max-filesize "$MIB" \
        --output "$WORKDIR/$filename.DIGESTS" "$STAGE_BASE.DIGESTS"
    verified_digests="$WORKDIR/$filename.DIGESTS.verified"
    run gpgv --homedir "$WORKDIR" --output "$verified_digests" --keyring "$keyring" \
        "$WORKDIR/$filename.DIGESTS"
    STAGE_DIGEST=$(sha512_digest "$verified_digests" "$filename")
    [[ $STAGE_DIGEST =~ ^[0-9a-fA-F]{128}$ ]] || die "No signed SHA-512 checksum was found."
}

download_and_extract_stage() {
    local filename archive actual keyring
    filename=${STAGE_PATH##*/}
    keyring="$WORKDIR/gentoo-release.gpg"
    [[ -n $filename && $STAGE_SIZE =~ ^[1-9][0-9]*$ && -n $STAGE_BASE &&
        $STAGE_DIGEST =~ ^[0-9a-fA-F]{128}$ && -r $keyring && -r $WORKDIR/$filename.asc ]] ||
        die "Verified stage metadata is incomplete."
    STAGE_DIR=$(mktemp -d "$TARGET/.autogentoo-stage.XXXXXX")
    archive="$STAGE_DIR/$filename"
    run curl --disable --proto '=https' --proto-redir '=https' --tlsv1.2 --fail --location \
        --show-error --remove-on-error --max-filesize "$STAGE_SIZE" \
        --output "$archive" "$STAGE_BASE"
    run gpgv --homedir "$WORKDIR" --keyring "$keyring" "$WORKDIR/$filename.asc" "$archive"
    actual=$(stat -c %s "$archive")
    (( actual == STAGE_SIZE )) || die "The stage size does not match its signed pointer."
    (cd "$STAGE_DIR" && printf '%s  %s\n' "$STAGE_DIGEST" "$filename" | sha512sum -c -) | tee -a "$LOG"
    run tar xpf "$archive" --xattrs-include='*.*' --numeric-owner -C "$TARGET"
    run rm -rf -- "$STAGE_DIR"
    STAGE_DIR=""
    run rm -rf -- "$WORKDIR"
    WORKDIR=""
}

