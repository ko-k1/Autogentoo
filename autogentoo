create_user() {
    local groups=wheel,video existing
    existing=$(awk -F: -v name="$USERNAME" '$1 == name { print $1; exit }' \
        "$TARGET/etc/passwd") || die "The target account database could not be read."
    [[ -z $existing ]] || die "The account $USERNAME already exists in the target stage."
    valid_password_hash "$USER_PASSWORD_HASH" ||
        die "The password hash is missing or invalid."
    [[ $PROFILE == desktop ]] && groups+=,audio,input
    chroot_run /usr/sbin/useradd -m -G "$groups" -s /bin/bash "$USERNAME"
    printf '%s:%s\n' "$USERNAME" "$USER_PASSWORD_HASH" | chroot "$TARGET" /usr/bin/env -i \
        HOME=/root PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
        /usr/sbin/chpasswd -e
    if (( ROOT_SAME_PASSWORD )); then
        printf 'root:%s\n' "$USER_PASSWORD_HASH" | chroot "$TARGET" /usr/bin/env -i \
            HOME=/root PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
            /usr/sbin/chpasswd -e
    else
        chroot_run /usr/bin/passwd -l root
    fi
    unset USER_PASSWORD_HASH
    run mkdir -p "$TARGET/etc/sudoers.d"
    cat >"$TARGET/etc/sudoers.d/wheel" <<'EOF'
%wheel ALL=(ALL:ALL) ALL
EOF
    chmod 0440 "$TARGET/etc/sudoers.d/wheel"
    chroot_run /usr/sbin/visudo -cf /etc/sudoers
}

write_fstab() {
